{
    "name": "@vex-chat/types",
    "version": "2.0.0",
    "description": "Wire protocol types for the Vex encrypted chat platform",
    "type": "module",
    "sideEffects": false,
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./openapi.json": "./openapi.json",
        "./asyncapi.json": "./asyncapi.json"
    },
    "files": [
        "dist",
        "src/index.ts",
        "src/schemas",
        "openapi.json",
        "asyncapi.json",
        "LICENSE"
    ],
    "author": "Extra <extrahash@protonmail.com>",
    "license": "AGPL-3.0-or-later",
    "engines": {
        "node": ">=18.0.0"
    },
    "scripts": {
        "build": "tsc -p tsconfig.build.json",
        "build:clean": "rimraf dist && tsc -p tsconfig.build.json",
        "prepack": "pnpm run build",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "lint": "eslint src/",
        "lint:fix": "eslint src/ --fix",
        "license:check": "license-checker scan --allowOnly MIT ISC BSD-2-Clause BSD-3-Clause Apache-2.0 0BSD MPL-2.0 CC0-1.0 CC-BY-4.0 Unlicense BlueOak-1.0.0 Python-2.0 Zlib PSF-2.0 Artistic-2.0 AGPL-3.0-or-later --ignoreRootPackageLicense --disableReport",
        "lint:pkg": "publint --strict",
        "lint:types": "attw --pack . --ignore-rules cjs-resolves-to-esm",
        "lint:api": "api-extractor run --local --verbose",
        "openapi": "npx tsx scripts/generate-openapi.ts",
        "asyncapi": "npx tsx scripts/generate-asyncapi.ts",
        "specs": "pnpm run openapi && pnpm run asyncapi",
        "post-version": "pnpm run specs",
        "lint:specs": "spectral lint openapi.json asyncapi.json",
        "specs:check": "pnpm run specs && git diff --exit-code openapi.json asyncapi.json",
        "test:types": "tsc --noEmit"
    },
    "dependencies": {
        "zod": "catalog:"
    },
    "devDependencies": {
        "@arethetypeswrong/cli": "0.18.2",
        "@asteasolutions/zod-to-openapi": "8.5.0",
        "@asyncapi/parser": "3.6.0",
        "@changesets/cli": "2.30.0",
        "@microsoft/api-extractor": "7.58.2",
        "@stoplight/spectral-cli": "6.15.0",
        "@types/node": "catalog:",
        "@vex-chat/eslint-config": "workspace:*",
        "eslint": "10.2.0",
        "eslint-config-prettier": "10.1.8",
        "eslint-plugin-perfectionist": "5.8.0",
        "husky": "9.1.7",
        "lint-staged": "16.4.0",
        "prettier": "3.8.2",
        "publint": "0.3.18",
        "rimraf": "6.1.3",
        "type-coverage": "2.29.7",
        "typescript": "catalog:",
        "typescript-eslint": "8.58.1"
    },
    "typeCoverage": {
        "atLeast": 100,
        "strict": true,
        "ignoreCatch": true
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/vex-protocol/protocol.git",
        "directory": "packages/types"
    },
    "bugs": {
        "url": "https://github.com/vex-protocol/protocol/issues"
    },
    "homepage": "https://github.com/vex-protocol/protocol/tree/master/packages/types#readme",
    "publishConfig": {
        "access": "public",
        "registry": "https://registry.npmjs.org/"
    }
}
