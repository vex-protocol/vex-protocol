{
  "name": "@vex-chat/types",
  "version": "1.0.0-rc.1",
  "description": "Types for vex",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "author": "Extra <extrahash@protonmail.com>",
  "license": "AGPL-3.0-or-later",
  "scripts": {
    "start": "node ./dist/index.js",
    "build": "rimraf dist && tsc",
    "prepack": "npm run build",
    "prettier": "prettier '**/*.{ts,tsx,json,md}' --ignore-path .gitignore --write",
    "lint": "eslint src/**/*.ts",
    "lint-fix": "eslint src/**/*.ts --fix",
    "prepare": "husky"
  },
  "peerDependencies": {
    "tweetnacl": "^1.0.3"
  },
  "peerDependenciesMeta": {
    "tweetnacl": {
      "optional": true
    }
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@types/node": "^24.12.2",
    "tweetnacl": "^1.0.3",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.2.0",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.2"
  },
  "lint-staged": {
    "src/**/*.{ts}": [
      "eslint --fix"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vex-chat/types-js.git"
  },
  "bugs": {
    "url": "https://github.com/vex-chat/types-js/issues"
  },
  "homepage": "https://github.com/vex-chat/types-js#readme"
}
