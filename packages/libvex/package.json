{
    "name": "@vex-chat/libvex",
    "version": "1.0.0-rc.0",
    "description": "Library for communicating with xchat server.",
    "type": "module",
    "sideEffects": false,
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "files": [
        "dist"
    ],
    "author": "Extra <extrahash@protonmail.com>",
    "license": "AGPL-3.0-or-later",
    "engines": {
        "node": ">=24.0.0"
    },
    "scripts": {
        "build": "rimraf dist && tsc",
        "prettier": "prettier '**/*.{ts,tsx,json,md}' --trailing-comma es5 --tab-width 4 --ignore-path .gitignore --arrow-parens always --write",
        "prepack": "npm run build",
        "docs": "npx typedoc --options typedoc.json",
        "test": "vitest run"
    },
    "peerDependencies": {
        "@vex-chat/crypto": "^1.0.0-rc.0",
        "@vex-chat/types": "^1.0.0-rc.0"
    },
    "devDependencies": {
        "@types/browser-or-node": "^1.3.0",
        "@types/btoa": "^1.2.3",
        "@types/ed2curve": "^0.2.4",
        "@types/node": "^24.12.2",
        "@types/object-hash": "^1.3.4",
        "@types/uuid": "^8.3.0",
        "@types/ws": "^8.5.10",
        "@vex-chat/crypto": "file:.yalc/@vex-chat/crypto",
        "@vex-chat/types": "file:.yalc/@vex-chat/types",
        "dotenv": "^8.2.0",
        "prettier": "^3.2.0",
        "rimraf": "^6.1.3",
        "typedoc": "^0.28.0",
        "typescript": "^6.0.2",
        "vitest": "^3.0.0"
    },
    "overrides": {
        "@types/ws": "^8.5.10"
    },
    "dependencies": {
        "@extrahash/sleep": "^1.0.0",
        "msgpackr": "1.11.8",
        "axios": "^1.7.0",
        "browser-or-node": "^1.3.0",
        "btoa": "^1.2.1",
        "chalk": "^4.1.0",
        "knex": "^3.1.0",
        "object-hash": "^2.1.1",
        "parse-duration": "^2.0.0",
        "better-sqlite3": "^11.0.0",
        "tweetnacl": "^1.0.3",
        "uuid": "^8.3.1",
        "winston": "^3.3.3",
        "ws": "^8.17.0"
    },
    "directories": {
        "doc": "docs"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/vex-chat/vex-js.git"
    },
    "bugs": {
        "url": "https://github.com/vex-chat/vex-js/issues"
    },
    "homepage": "https://github.com/vex-chat/vex-js#readme",
    "publishConfig": {
        "access": "public",
        "registry": "https://registry.npmjs.org/"
    }
}
