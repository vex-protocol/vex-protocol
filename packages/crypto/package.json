{
    "name": "@vex-chat/crypto",
    "version": "1.1.1",
    "description": "Crypto primitives for Vex",
    "type": "module",
    "sideEffects": false,
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "files": [
        "dist"
    ],
    "author": "Extra <extrahash@protonmail.com>",
    "license": "AGPL-3.0-or-later",
    "scripts": {
        "build": "tsc",
        "build:clean": "rimraf dist && tsc",
        "prepack": "npm run build",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "lint": "eslint src/",
        "lint:fix": "eslint src/ --fix",
        "prepublish": "npm run build",
        "test": "vitest run"
    },
    "peerDependencies": {
        "@vex-chat/types": "^1.0.0-rc.1",
        "typescript": ">=5.9.0 || >=6.0.0"
    },
    "peerDependenciesMeta": {
        "typescript": {
            "optional": true
        }
    },
    "dependencies": {
        "@noble/hashes": "^2.0.1",
        "@stablelib/base64": "^2.0.1",
        "@stablelib/utf8": "^2.1.0",
        "bip39": "^3.1.0",
        "ed2curve": "^0.3.0",
        "msgpackr": "1.11.8",
        "tweetnacl": "^1.0.3"
    },
    "devDependencies": {
        "@changesets/cli": "^2.29.8",
        "@types/create-hmac": "^1.1.3",
        "@types/ed2curve": "^0.2.4",
        "@types/node": "^24.12.2",
        "@typescript-eslint/eslint-plugin": "^8.57.1",
        "@typescript-eslint/parser": "^8.57.1",
        "@vex-chat/types": "^1.0.1",
        "eslint": "^10.1.0",
        "eslint-config-prettier": "^9.0.0",
        "husky": "^9.0.0",
        "lint-staged": "^15.2.0",
        "prettier": "^3.2.0",
        "rimraf": "^6.1.3",
        "typescript": "^6.0.2",
        "vitest": "^3.0.0"
    },
    "lint-staged": {
        "*.ts": [
            "eslint --fix",
            "prettier --write"
        ]
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/vex-chat/libvex-js.git"
    },
    "bugs": {
        "url": "https://github.com/vex-chat/libvex-js/issues"
    },
    "homepage": "https://github.com/vex-chat/libvex-js#readme",
    "publishConfig": {
        "access": "public",
        "registry": "https://registry.npmjs.org/"
    }
}
