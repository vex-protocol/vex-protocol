{
    "name": "@vex-chat/crypto",
    "version": "3.0.0",
    "description": "Crypto primitives for the Vex encrypted chat platform",
    "type": "module",
    "sideEffects": false,
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "files": [
        "dist",
        "src",
        "LICENSE",
        "LICENSE-COMMERCIAL",
        "LICENSING.md",
        "CLA.md"
    ],
    "author": "Extra <extrahash@protonmail.com>",
    "license": "AGPL-3.0-or-later",
    "engines": {
        "node": ">=24.0.0"
    },
    "scripts": {
        "build": "tsc -p tsconfig.build.json",
        "build:clean": "rimraf dist && tsc -p tsconfig.build.json",
        "prepack": "pnpm run build",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "lint": "eslint src/",
        "lint:fix": "eslint src/ --fix",
        "license:check": "license-checker scan --allowOnly MIT ISC BSD-2-Clause BSD-3-Clause Apache-2.0 0BSD MPL-2.0 CC0-1.0 CC-BY-4.0 Unlicense BlueOak-1.0.0 Python-2.0 Zlib PSF-2.0 Artistic-2.0 AGPL-3.0-or-later --ignoreRootPackageLicense --disableReport",
        "lint:pkg": "publint --strict",
        "lint:types": "attw --pack . --ignore-rules cjs-resolves-to-esm",
        "lint:api": "api-extractor run --local --verbose",
        "docs": "npx typedoc --options typedoc.json",
        "test": "vitest run",
        "test:core": "vitest run --project core",
        "test:async-api": "vitest run --project async-api",
        "test:types": "tsc --noEmit",
        "prepublish": "pnpm run build"
    },
    "peerDependencies": {
        "@vex-chat/types": "workspace:^",
        "typescript": ">=5.9.0 || >=6.0.0"
    },
    "peerDependenciesMeta": {
        "typescript": {
            "optional": true
        }
    },
    "dependencies": {
        "@noble/curves": "1.4.0",
        "@noble/hashes": "2.2.0",
        "@stablelib/base64": "2.0.1",
        "@stablelib/utf8": "2.1.0",
        "bip39": "3.1.0",
        "ed2curve": "0.3.0",
        "msgpackr": "catalog:",
        "tweetnacl": "1.0.3",
        "zod": "catalog:"
    },
    "devDependencies": {
        "@arethetypeswrong/cli": "0.18.2",
        "@changesets/cli": "2.30.0",
        "@microsoft/api-extractor": "7.58.2",
        "@types/ed2curve": "0.2.4",
        "@types/node": "catalog:",
        "@vex-chat/eslint-config": "workspace:*",
        "@vex-chat/types": "workspace:^",
        "@vitest/eslint-plugin": "1.6.15",
        "eslint": "10.2.0",
        "eslint-config-prettier": "10.1.8",
        "eslint-plugin-perfectionist": "5.8.0",
        "husky": "9.1.7",
        "lint-staged": "16.4.0",
        "prettier": "3.8.2",
        "publint": "0.3.18",
        "rimraf": "6.1.3",
        "type-coverage": "2.29.7",
        "typedoc": "0.28.18",
        "typescript": "catalog:",
        "typescript-eslint": "8.58.1",
        "vitest": "catalog:"
    },
    "directories": {
        "doc": "docs"
    },
    "typeCoverage": {
        "atLeast": 100,
        "strict": true,
        "ignoreCatch": true
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/vex-protocol/vex-protocol.git",
        "directory": "packages/crypto"
    },
    "bugs": {
        "url": "https://github.com/vex-protocol/vex-protocol/issues"
    },
    "homepage": "https://github.com/vex-protocol/vex-protocol/tree/master/packages/crypto#readme",
    "publishConfig": {
        "access": "public",
        "registry": "https://registry.npmjs.org/"
    }
}
