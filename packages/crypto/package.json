{
    "name": "@vex-chat/crypto",
    "version": "1.2.0-rc.1",
    "description": "Crypto primitives for Vex",
    "type": "module",
    "sideEffects": false,
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "files": [
        "dist",
        "src",
        "LICENSE"
    ],
    "author": "Extra <extrahash@protonmail.com>",
    "license": "AGPL-3.0-or-later",
    "engines": {
        "node": ">=24.0.0",
        "npm": ">=10.0.0"
    },
    "packageManager": "npm@10.9.2",
    "scripts": {
        "prepare": "husky",
        "preinstall": "npx only-allow npm",
        "build": "tsc -p tsconfig.build.json",
        "build:clean": "rimraf dist && tsc -p tsconfig.build.json",
        "prepack": "npm run build",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "lint": "eslint src/",
        "lint:fix": "eslint src/ --fix",
        "prepublish": "npm run build",
        "test": "vitest run",
        "license:check": "npx @onebeyond/license-checker scan --allowOnly MIT ISC BSD-2-Clause BSD-3-Clause Apache-2.0 0BSD MPL-2.0 CC0-1.0 CC-BY-4.0 Unlicense BlueOak-1.0.0 Python-2.0 Zlib PSF-2.0 Artistic-2.0 AGPL-3.0-or-later --ignoreRootPackageLicense --disableReport"
    },
    "peerDependencies": {
        "@vex-chat/types": "^2.0.0-rc.0",
        "typescript": ">=5.9.0 || >=6.0.0"
    },
    "peerDependenciesMeta": {
        "typescript": {
            "optional": true
        }
    },
    "dependencies": {
        "@noble/hashes": "^2.0.1",
        "@stablelib/base64": "^2.0.1",
        "@stablelib/utf8": "^2.1.0",
        "bip39": "^3.1.0",
        "ed2curve": "^0.3.0",
        "msgpackr": "1.11.8",
        "tweetnacl": "^1.0.3"
    },
    "devDependencies": {
        "@changesets/cli": "^2.29.8",
        "@types/create-hmac": "^1.1.3",
        "@types/ed2curve": "^0.2.4",
        "@types/node": "^24.12.2",
        "@vex-chat/types": "^2.0.0-rc.0",
        "@vitest/eslint-plugin": "^1.6.14",
        "eslint": "^10.1.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-perfectionist": "^5.8.0",
        "husky": "^9.0.0",
        "lint-staged": "^15.2.0",
        "prettier": "^3.2.0",
        "rimraf": "^6.1.3",
        "type-coverage": "^2.29.7",
        "typescript": "^6.0.2",
        "typescript-eslint": "^8.32.1",
        "vitest": "^3.0.0"
    },
    "lint-staged": {
        "src/**/*.ts": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{json,md}": [
            "prettier --write"
        ]
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/vex-protocol/crypto-js.git"
    },
    "bugs": {
        "url": "https://github.com/vex-protocol/crypto-js/issues"
    },
    "homepage": "https://github.com/vex-protocol/crypto-js#readme",
    "publishConfig": {
        "access": "public",
        "registry": "https://registry.npmjs.org/"
    }
}
