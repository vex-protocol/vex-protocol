{
    "name": "@vex-chat/crypto",
    "version": "2.1.1",
    "description": "Crypto primitives for the Vex encrypted chat platform",
    "type": "module",
    "sideEffects": false,
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "files": [
        "dist",
        "src",
        "LICENSE",
        "LICENSE-COMMERCIAL",
        "LICENSING.md",
        "CLA.md"
    ],
    "author": "Extra <extrahash@protonmail.com>",
    "license": "AGPL-3.0-or-later",
    "engines": {
        "node": ">=24.0.0",
        "npm": ">=10.0.0"
    },
    "packageManager": "npm@10.9.2",
    "scripts": {
        "prepare": "husky",
        "preinstall": "npx only-allow npm",
        "build": "tsc -p tsconfig.build.json",
        "build:clean": "rimraf dist && tsc -p tsconfig.build.json",
        "prepack": "npm run build",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "lint": "eslint src/",
        "lint:fix": "eslint src/ --fix",
        "license:check": "npx @onebeyond/license-checker scan --allowOnly MIT ISC BSD-2-Clause BSD-3-Clause Apache-2.0 0BSD MPL-2.0 CC0-1.0 CC-BY-4.0 Unlicense BlueOak-1.0.0 Python-2.0 Zlib PSF-2.0 Artistic-2.0 AGPL-3.0-or-later --ignoreRootPackageLicense --disableReport",
        "lint:pkg": "publint --strict",
        "lint:types": "attw --pack . --ignore-rules cjs-resolves-to-esm",
        "lint:api": "api-extractor run --local --verbose",
        "docs": "npx typedoc --options typedoc.json",
        "test": "vitest run",
        "test:core": "vitest run --project core",
        "test:async-api": "vitest run --project async-api",
        "test:types": "tsc --noEmit",
        "prepublish": "npm run build"
    },
    "peerDependencies": {
        "@vex-chat/types": "2.0.0",
        "typescript": ">=5.9.0 || >=6.0.0"
    },
    "peerDependenciesMeta": {
        "typescript": {
            "optional": true
        }
    },
    "dependencies": {
        "@noble/curves": "1.4.0",
        "@noble/hashes": "2.2.0",
        "@stablelib/base64": "2.0.1",
        "@stablelib/utf8": "2.1.0",
        "bip39": "3.1.0",
        "ed2curve": "0.3.0",
        "msgpackr": "1.11.9",
        "tweetnacl": "1.0.3",
        "zod": "4.3.6"
    },
    "devDependencies": {
        "@arethetypeswrong/cli": "0.18.2",
        "@changesets/cli": "2.30.0",
        "@microsoft/api-extractor": "7.58.2",
        "@types/ed2curve": "0.2.4",
        "@types/node": "25.6.0",
        "@vex-chat/types": "2.0.0",
        "@vitest/eslint-plugin": "1.6.15",
        "eslint": "10.2.0",
        "eslint-config-prettier": "10.1.8",
        "eslint-plugin-perfectionist": "5.8.0",
        "husky": "9.1.7",
        "lint-staged": "16.4.0",
        "prettier": "3.8.2",
        "publint": "0.3.18",
        "rimraf": "6.1.3",
        "type-coverage": "2.29.7",
        "typedoc": "0.28.18",
        "typescript": "6.0.2",
        "typescript-eslint": "8.58.1",
        "vitest": "4.1.4"
    },
    "directories": {
        "doc": "docs"
    },
    "overrides": {
        "postcss": "8.5.10"
    },
    "typeCoverage": {
        "atLeast": 100,
        "strict": true,
        "ignoreCatch": true
    },
    "lint-staged": {
        "src/**/*.ts": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{json,md,yaml,yml}": [
            "prettier --write"
        ]
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/vex-protocol/crypto-js.git"
    },
    "bugs": {
        "url": "https://github.com/vex-protocol/crypto-js/issues"
    },
    "homepage": "https://github.com/vex-protocol/crypto-js#readme",
    "publishConfig": {
        "access": "public",
        "registry": "https://registry.npmjs.org/"
    }
}
