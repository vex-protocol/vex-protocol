{
    "name": "protocol",
    "private": true,
    "type": "module",
    "scripts": {
        "preinstall": "npx only-allow pnpm",
        "prepare": "husky",
        "build": "pnpm -r --if-present build",
        "test": "pnpm -r --if-present test",
        "typecheck": "pnpm -r --if-present typecheck",
        "lint": "pnpm -r --if-present lint",
        "lint:fix": "pnpm -r --if-present lint:fix",
        "copyright:check": "pnpm -r --if-present copyright:check",
        "copyright:apply": "pnpm -r --if-present copyright:apply",
        "lint:pkg": "pnpm -r --if-present lint:pkg",
        "lint:types": "pnpm -r --if-present lint:types",
        "lint:api": "pnpm -r --if-present lint:api",
        "lint:specs": "pnpm -r --if-present lint:specs",
        "specs:check": "pnpm -r --if-present specs:check",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "license:check": "pnpm -r --if-present license:check",
        "version": "pnpm exec changeset version && pnpm -r --if-present run post-version"
    },
    "packageManager": "pnpm@10.30.3",
    "engines": {
        "node": ">=24.0.0"
    },
    "pnpm": {
        "overrides": {
            "@types/readable-stream": "4.0.11",
            "@types/ws": "8.18.1",
            "lodash": "^4.18.1",
            "minimatch": "^10.2.5",
            "postcss": "8.5.10",
            "rollup": "^4.60.1",
            "uuid": "14.0.0"
        }
    },
    "devDependencies": {
        "@changesets/changelog-github": "0.5.1",
        "@changesets/cli": "2.30.0",
        "@onebeyond/license-checker": "2.2.0",
        "eslint": "10.2.0",
        "eslint-config-prettier": "10.1.8",
        "husky": "9.1.7",
        "lint-staged": "16.4.0",
        "prettier": "3.8.2",
        "typescript": "catalog:",
        "typescript-eslint": "8.58.1"
    },
    "license": "AGPL-3.0-or-later"
}
