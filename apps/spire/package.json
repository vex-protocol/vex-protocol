{
    "name": "@vex-chat/spire",
    "version": "0.9.0-rc.0",
    "description": "Vex server implementation in NodeJS.",
    "private": true,
    "type": "module",
    "author": "Extra <extrahash@protonmail.com>",
    "license": "AGPL-3.0-or-later",
    "engines": {
        "node": ">=24.0.0",
        "npm": ">=10.0.0"
    },
    "packageManager": "npm@10.9.2",
    "scripts": {
        "preinstall": "npx only-allow npm",
        "start": "node src/run.ts",
        "start:built": "node ./dist/run.js",
        "restart": "pm2 restart spire && pm2 logs spire",
        "build": "tsc",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "lint": "eslint src/",
        "lint:fix": "eslint src/ --fix",
        "prepare": "husky",
        "test": "vitest run",
        "gen-spk": "node scripts/gen-spk.js",
        "docs": "node ./scripts/generate-docs.js",
        "license:check": "npx @onebeyond/license-checker scan --allowOnly MIT ISC BSD-2-Clause BSD-3-Clause Apache-2.0 0BSD MPL-2.0 CC0-1.0 CC-BY-4.0 Unlicense BlueOak-1.0.0 Python-2.0 Zlib PSF-2.0 Artistic-2.0 AGPL-3.0-or-later WTFPL --ignoreRootPackageLicense --disableReport",
        "service:status-monitor": "node ./services/status-monitor/index.js",
        "service:status-monitor:clear-history": "node ./services/status-monitor/clear-history.js",
        "service:deploy-hook": "node ./services/deploy-hook/index.js",
        "monitor": "node ./services/status-monitor/index.js"
    },
    "devDependencies": {
        "@types/better-sqlite3": "^7.6.0",
        "@types/cors": "^2.8.17",
        "@types/express": "^5.0.0",
        "@types/jsonwebtoken": "^9.0.0",
        "@types/morgan": "^1.9.9",
        "@types/multer": "^2.0.0",
        "@types/node": "^24.12.2",
        "@types/swagger-ui-express": "^4.1.8",
        "@types/uuid": "^10.0.0",
        "@types/ws": "^8.5.10",
        "@vex-chat/crypto": "^1.2.0-rc.1",
        "@vex-chat/types": "^2.0.0-rc.1",
        "@vitest/eslint-plugin": "^1.6.14",
        "eslint": "^10.1.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-n": "^17.24.0",
        "eslint-plugin-perfectionist": "^5.8.0",
        "husky": "^9.1.7",
        "lint-staged": "^16.3.2",
        "prettier": "^3.2.0",
        "type-coverage": "^2.29.7",
        "typedoc": "^0.28.18",
        "typescript": "^6.0.2",
        "typescript-eslint": "^8.32.1",
        "vitest": "^3.0.0"
    },
    "lint-staged": {
        "*.ts": [
            "eslint --fix",
            "prettier --write"
        ]
    },
    "overrides": {
        "@types/ws": "^8.5.10",
        "@types/readable-stream": "4.0.11"
    },
    "dependencies": {
        "better-sqlite3": "^11.0.0",
        "cors": "^2.8.5",
        "dotenv": "^17.0.0",
        "express": "^5.1.0",
        "file-type": "^22.0.0",
        "helmet": "^8.1.0",
        "jsonwebtoken": "^9.0.2",
        "kysely": "^0.28.15",
        "morgan": "^1.10.0",
        "msgpackr": "1.11.8",
        "multer": "^2.0.0",
        "parse-duration": "^2.0.0",
        "picocolors": "^1.1.1",
        "swagger-ui-express": "^5.0.1",
        "tweetnacl": "^1.0.3",
        "uuid": "^8.3.1",
        "winston": "^3.3.3",
        "ws": "^8.17.0",
        "zod": "^4.3.6"
    }
}
