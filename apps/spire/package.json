{
    "name": "@vex-chat/spire",
    "version": "0.9.0-rc.0",
    "description": "Vex server implementation in NodeJS.",
    "private": true,
    "type": "module",
    "author": "Extra <extrahash@protonmail.com>",
    "license": "AGPL-3.0-or-later",
    "engines": {
        "node": ">=24.0.0"
    },
    "scripts": {
        "start": "node src/run.ts",
        "start:built": "node ./dist/run.js",
        "restart": "pm2 restart spire && pm2 logs spire",
        "build": "tsc",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "lint": "eslint src/",
        "lint:fix": "eslint src/ --fix",
        "prepare": "husky",
        "test": "vitest run",
        "gen-spk": "node scripts/gen-spk.js",
        "docs": "node ./scripts/generate-docs.js",
        "service:status-monitor": "node ./services/status-monitor/index.js",
        "service:status-monitor:clear-history": "node ./services/status-monitor/clear-history.js",
        "service:deploy-hook": "node ./services/deploy-hook/index.js",
        "monitor": "node ./services/status-monitor/index.js"
    },
    "devDependencies": {
        "@types/better-sqlite3": "^7.6.0",
        "@types/cookie-parser": "^1.4.2",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/express-ws": "^3.0.5",
        "@types/jsonwebtoken": "^9.0.0",
        "@types/morgan": "^1.9.9",
        "@types/multer": "^1.4.12",
        "@types/node": "^24.12.2",
        "@types/swagger-ui-express": "^4.1.8",
        "@types/uuid": "^10.0.0",
        "@types/ws": "^8.5.10",
        "@vex-chat/crypto": "1.1.0-rc.1",
        "@vex-chat/types": "^1.0.0-rc.1",
        "@typescript-eslint/eslint-plugin": "^8.57.1",
        "@typescript-eslint/parser": "^8.57.1",
        "eslint": "^10.1.0",
        "eslint-config-prettier": "^9.0.0",
        "husky": "^9.1.7",
        "lint-staged": "^16.3.2",
        "prettier": "^3.2.0",
        "typedoc": "^0.28.18",
        "typescript": "^6.0.2",
        "vitest": "^3.0.0"
    },
    "lint-staged": {
        "*.ts": [
            "eslint --fix",
            "prettier --write"
        ]
    },
    "overrides": {
        "@types/express": "^4.17.21",
        "@types/express-serve-static-core": "^4.17.41",
        "@types/ws": "^8.5.10",
        "@types/readable-stream": "4.0.11"
    },
    "dependencies": {
        "@extrahash/sleep": "^1.0.0",
        "better-sqlite3": "^11.0.0",
        "chalk": "^4.1.0",
        "cookie-parser": "^1.4.5",
        "cors": "^2.8.5",
        "dotenv": "^17.0.0",
        "express": "^4.17.1",
        "express-ws": "^4.0.0",
        "file-type": "^22.0.0",
        "helmet": "^4.2.0",
        "jsonwebtoken": "^9.0.2",
        "knex": "^3.1.0",
        "morgan": "^1.10.0",
        "msgpackr": "1.11.8",
        "multer": "^2.0.0",
        "mysql": "^2.18.1",
        "parse-duration": "^2.0.0",
        "swagger-ui-express": "^5.0.1",
        "tweetnacl": "^1.0.3",
        "uuid": "^8.3.1",
        "winston": "^3.3.3",
        "ws": "^8.17.0"
    }
}
