# Crypto mode (must match the kind of SPK you generate):
#   tweetnacl  — `pnpm --filter @vex-chat/spire gen-spk`  → Ed25519 SPK (128 hex)
#   fips       — `pnpm --filter @vex-chat/spire gen-spk-fips` → P-256 PKCS#8 SPK (longer hex), and set SPIRE_FIPS below
#
# SPK: tweetnacl = 128 hex. FIPS = PKCS#8 P-256 (longer hex) — not interchangeable.
SPK=

# HMAC key for JWT signing — must be separate from SPK (64 hex chars = 32 bytes)
JWT_SECRET=

# CANARY=true

# P-256 / Web Crypto. Only `true` or `1` enable FIPS; anything else = tweetnacl.
# For Docker: can also run `SPIRE_FIPS=true docker compose up` to override this file.
SPIRE_FIPS=false

# Database engine: sqlite3 (default) | sqlite3mem (in-memory, for testing)
DB_TYPE=sqlite3

# HTTP listen port. Unset: 16777. Set to override.
# API_PORT=16777

# Optional comma-separated CORS origin allowlist (e.g. https://app.vex.wtf,https://vex.wtf).
# If unset, Spire reflects the browser's Origin (any host) so self-hosted and
# third-party clients work without extra config. Set this to lock down which
# frontends may use browser credentials against your instance.
# CORS_ORIGINS=

# ── Passkeys / WebAuthn ────────────────────────────────────────────────
# Passkeys are a second-class admin credential bound to a user's account:
# they can list/delete devices and approve/reject pending enrollments,
# but can't send or receive mail. Required for the /auth/passkey/*,
# /user/:id/passkeys/*, and /passkey/* routes; without them those
# endpoints 500 with a clear "Passkeys are not configured" message.
#
# eTLD+1 of the host the user-agent loaded the client from. No scheme,
# no port. Subdomains inherit. e.g. vex.wtf or localhost (browser dev).
# SPIRE_PASSKEY_RP_ID=
# Display name shown in the OS passkey prompt. Defaults to "Vex".
# SPIRE_PASSKEY_RP_NAME=Vex
# Comma-separated allowlist of expected client `origin` values inside
# the assertion's clientDataJSON. Web is `https://host`, iOS native is
# `ios:bundle-id:<id>` (or `https://<RP_ID>` for Apple Passkeys via
# Credential Manager). The native-Android equivalent
# (`android:apk-key-hash:<base64url>`) is derived automatically from
# SPIRE_PASSKEY_ANDROID_FINGERPRINTS below — list those fingerprints
# once and they'll be added to this allowlist for you.
# SPIRE_PASSKEY_ORIGINS=

# Optional: serve the WebAuthn well-known association files directly
# from spire so Apple / Google can verify the app↔domain link without
# you self-hosting them on the RP host. Mounted before the rate
# limiter so periodic platform fetches are never 429'd. Each pair of
# vars 404s independently when unset, so you can advertise iOS only,
# Android only, or both. The Android fingerprints are also reused
# server-side as `android:apk-key-hash:<base64url>` entries in the
# WebAuthn `expectedOrigin` allowlist (without that, native-Android
# assertions are rejected at the origin check, which the mobile UI
# surfaces as a generic "RP failed" error).
# SPIRE_PASSKEY_IOS_APP_IDS=ABCDE12345.chat.vex.mobile
# SPIRE_PASSKEY_ANDROID_PACKAGE=chat.vex.mobile
# SPIRE_PASSKEY_ANDROID_FINGERPRINTS=AA:BB:CC:...,DD:EE:FF:...

# Dev escape hatch: when set, requests with header `x-dev-api-key: <same value>`
# skip in-process rate limiters (for local load testing, `pnpm --filter @vex-chat/spire stress:web`, etc.).
# Never set in production. Same value must be set on the stress client if you use it.
# DEV_API_KEY=
# SPIRE_STRESS_HOST=127.0.0.1:16777
# SPIRE_STRESS_CONCURRENCY=25
# SPIRE_STRESS_ROUNDS=25         # optional: exit after N bursts (default: run until Ctrl+C)
# SPIRE_STRESS_FOREVER=0         # optional: 10 bursts then exit if SPIRE_STRESS_ROUNDS is unset
# SPIRE_STRESS_SCENARIO=mixed
#   (mixed | whoami | servers | chat — chat = WebSocket + group sends + reads; see scripts/stress/spire-stress.ts)
# SPIRE_STRESS_CLIENTS=1
# SPIRE_STRESS_WS=0               # optional; chat scenario always opens WebSocket
# SPIRE_STRESS_USERNAME=
# SPIRE_STRESS_PASSWORD=
# SPIRE_STRESS_JSON=1   # append JSON after the human-readable summary (for scripts)
