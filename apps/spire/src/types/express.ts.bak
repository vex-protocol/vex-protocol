import type { Device, User } from "@vex-chat/types";

/**
 * Augment Express's Request with the properties set by checkAuth
 * and checkDevice middleware. They're optional because not every
 * request passes through those middlewares successfully.
 */
declare module "express-serve-static-core" {
    interface Request {
        bearerToken?: string;
        device?: Device;
        exp?: number;
        user?: User;
    }
}
