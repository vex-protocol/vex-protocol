node_modules
dist
*.tsbuildinfo

# api-extractor intermediate output (the canonical report is at <pkg>/api/)
**/temp/*.api.md
**/temp/tsdoc-metadata.json

# Per-app env overrides — only .env.example is committed
.env
.env.local
.env.*.local

# Wrong lockfiles / package managers
package-lock.json
yarn.lock

# Local registry config
.npmrc

# Per-user agent / editor state
.claude/
.cursor/
.vscode/

# Beads (not used in this repo; if installed locally, ignore everything)
.beads/
.dolt/
*.db
